# RentMate AI - Backend Environment Variables Configuration
PORT=5000

# MongoDB Connection String (Atlas or Local Instance)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/rentmate?retryWrites=true&w=majority

# Secret key used for JWT signing and token verification
JWT_SECRET=rentmate_ai_secret_key_12345

# Google Gemini API key for compatibility scoring checks
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere...

# SMTP Configuration for Real Nodemailer Notifications (Optional Fallback to Ethereal Sandbox if omitted)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="RentMate AI" <no-reply@rentmate.ai>
